# Copy this file to `.env` and fill in your own API key(s).
# Only experiments/H_nl_robustness.py actually calls an LLM at runtime;
# every other driver and figure script runs offline against the shipped
# data and checkpoints, with no API key required.
#
# `.env` is git-ignored — your real key never leaves your machine.

# --- Default: Qwen via DashScope (OpenAI-compatible API) -------------------
# Sign up at https://dashscope.aliyun.com and create an API key.
DASHSCOPE_API_KEY=your-dashscope-key-here

# --- Alternative: any OpenAI-compatible provider --------------------------
# If you do not have a DashScope account, set both OPENAI_API_KEY and pass
# `--base-url <your-provider-endpoint>` on the command line. The Qwen
# backend uses the standard openai Python client under the hood, so any
# OpenAI-compatible endpoint will work.
#
# Examples:
#   OpenAI proper:      --base-url https://api.openai.com/v1
#   Together.ai:        --base-url https://api.together.xyz/v1
#   Anyscale:           --base-url https://api.endpoints.anyscale.com/v1
#   Local vLLM server:  --base-url http://localhost:8000/v1
#
# OPENAI_API_KEY=your-openai-key-here

# --- Optional: override default model -------------------------------------
# The paper used "qwen3-max". Override on the command line via --model.
#
# LLM_MODEL=qwen3-max
